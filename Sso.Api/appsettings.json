{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "ConnectionStrings": {
        "DefaultConnection": "Host=host;Port=5432;Database=database;Username=username;Password=password"
    },
    "AllowedHosts": "*",
    "Authentication": {
        "CookieName": "SsoAuth",
        "CookieDurationHours": "8"
    },
    "Cors": {
        "AllowedOrigins": ["URL do frontend"]
    },
    "Jwt": {
        "Issuer": "https://localhost:5000",
        "Audience": "sso-clients",
        "AccessTokenExpirationMinutes": 15,
        "RefreshTokenExpirationDays": 30,
        "PrivateKey": "GENERATE_AND_PASTE_HERE",
        "PublicKey": "GENERATE_AND_PASTE_HERE"
    }
}
